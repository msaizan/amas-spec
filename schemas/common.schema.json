{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/amcs/schemas/common.json",
  "title": "AMCS Common Types",
  "type": "object",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "id": {
      "type": "string",
      "minLength": 6,
      "maxLength": 128
    },
    "iso_datetime_or_null": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}